Cell[BoxData[{
 RowBox[{"ClearAll", "[", "growRandomHypergraph", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"growRandomHypergraph", "[", 
   RowBox[{
    RowBox[{"vertices_Integer", "?", "Positive"}], ",", 
    RowBox[{"edges_Integer", "?", "Positive"}], ",", 
    RowBox[{"edgeRange_", ":", "All"}]}], "]"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"RandomInteger", "[", 
     RowBox[{"(*", 
      RowBox[{"Vertices", ":"}], "*)"}], 
     RowBox[{
      RowBox[{"{", 
